# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials
# Get these values from Firebase Console > Project Settings > General > Your apps > SDK setup and configuration

REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Google Maps API Key (for address autocomplete and distance calculation)
# Get this from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Distance Matrix API, Geocoding API
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay API Keys (for payment gateway)
# Get these from: https://dashboard.razorpay.com/app/keys
# For testing, use Test Mode keys (rzp_test_xxxxx)
# For production, use Live Mode keys (rzp_live_xxxxx)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
REACT_APP_RAZORPAY_KEY_SECRET=your_key_secret_here

# OR For Stripe
# REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
